generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id                Int                @id @default(autoincrement())
  name_tm           String
  name_ru           String
  totalAmount       Decimal            @default(0) @db.Decimal(15, 2)
  paidAmount        Decimal            @default(0) @db.Decimal(15, 2)
  remainingDebt     Decimal            @default(0) @db.Decimal(15, 2)
  purchaseOrders    PurchaseOrder[]
  warehouseArrivals WarehouseArrival[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Product {
  id                   Int                 @id @default(autoincrement())
  name_tm              String
  name_ru              String
  unit                 Measurement?        @relation(fields: [unitId], references: [id])
  unitId               Int?
  productionCountry_tm String              @default("")
  productionCountry_ru String              @default("")
  items                PurchaseOrderItem[]
  warehouseArrivals    WarehouseArrival[]
  warehouseDispatches  WarehouseDispatch[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

enum OrderStatus {
  PENDING
  HALF_ARRIVED
  RECEIVED
}

model PurchaseOrder {
  id                Int                 @id @default(autoincrement())
  orderName         String              @default("")
  supplier          Supplier            @relation(fields: [supplierId], references: [id])
  supplierId        Int
  totalPrice        Decimal             @db.Decimal(15, 2)
  paidAmount        Decimal             @default(0) @db.Decimal(15, 2)
  lastPayDate       DateTime?
  status            OrderStatus         @default(PENDING)
  items             PurchaseOrderItem[]
  warehouseArrivals WarehouseArrival[]
  warehouseDispatches WarehouseDispatch[]
  expenses          PurchaseOrderExpenses?
  loans             Loan[]
  orderDate         DateTime            @default(now())
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model PurchaseOrderExpenses {
  id                 Int           @id @default(autoincrement())
  purchaseOrder      PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderId    Int           @unique
  expenses           Json          @default("{}")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model PurchaseOrderItem {
  id              Int           @id @default(autoincrement())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int
  product         Product       @relation(fields: [productId], references: [id])
  productId       Int
  quantity        Int
  unitPrice       Decimal       @db.Decimal(15, 2)
  totalPrice      Decimal       @db.Decimal(15, 2)
}

model Client {
  id                   Int                 @id @default(autoincrement())
  name_tm              String
  name_ru              String
  address_tm           String              @default("")
  address_ru           String              @default("")
  warehouseArrivals    WarehouseArrival[]
  warehouseDispatches  WarehouseDispatch[]
  loans                Loan[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

enum LoanType {
  IMPORT
  EXPORT
}

enum LoanStatus {
  OPEN
  PARTIAL
  CLOSED
}

model Loan {
  id               Int            @id @default(autoincrement())
  type             LoanType
  status           LoanStatus     @default(OPEN)
  client           Client         @relation(fields: [clientId], references: [id])
  clientId         Int
  totalAmount      Decimal        @db.Decimal(15, 2)
  paidAmount       Decimal        @default(0) @db.Decimal(15, 2)
  lastPayDate      DateTime?
  note             String         @default("")
  dispatchId       Int?
  dispatchGroupId  Int?
  dispatchName     String         @default("")
  purchaseOrder    PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId  Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Measurement {
  id        Int       @id @default(autoincrement())
  name_tm   String
  name_ru   String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum WarehouseType {
  IMPORT
  EXPORT
}

model WarehouseArrival {
  id              Int            @id @default(autoincrement())
  warehouseType   WarehouseType
  product         Product        @relation(fields: [productId], references: [id])
  productId       Int
  quantity        Int
  unitPrice       Decimal        @db.Decimal(15, 2)
  totalPrice      Decimal        @db.Decimal(15, 2)
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId      Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int?
  client          Client?        @relation(fields: [clientId], references: [id])
  clientId        Int?
  note            String         @default("")
  arrivalDate     DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model WarehouseDispatch {
  id              Int           @id @default(autoincrement())
  warehouseType   WarehouseType
  dispatchName    String        @default("")
  dispatchGroupId Int?
  product         Product       @relation(fields: [productId], references: [id])
  productId       Int
  quantity        Int
  sellPrice       Decimal       @default(0) @db.Decimal(15, 2)
  totalSellPrice  Decimal       @default(0) @db.Decimal(15, 2)
  client          Client?       @relation(fields: [clientId], references: [id])
  clientId        Int?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  purchaseOrderId Int?
  note            String        @default("")
  dispatchDate    DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  password     String
  refreshToken String?  @db.Text
  role         Role     @relation(fields: [roleId], references: [id])
  roleId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int

  @@id([roleId, permissionId])
}

model ExpenseFormula {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String   @default("")
  formula   String   @default("0")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
